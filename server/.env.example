# OpenAI (Whisper STT + TTS)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Internal Integration Token
# https://www.notion.so/profile/integrations から取得 (`ntn_...` または `secret_...`)
NOTION_API_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Custom Agent の UUID
# 不明な場合は README の手順で agents.list() から取得
NOTION_AGENT_ID=00000000-0000-0000-0000-000000000000

# サーバポート (任意、デフォルト 3000)
PORT=3000
